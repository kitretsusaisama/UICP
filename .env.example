# ─────────────────────────────────────────────────────────────────────────────
# Unified Identity Control Plane — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
GRPC_PORT=5000
SERVICE_NAME=uicp
SERVICE_VERSION=1.0.0

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uicp
DB_USER=uicp_user
DB_PASSWORD=change_me
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
# Set to true and provide REDIS_CLUSTER_NODES for Redis Cluster mode
REDIS_CLUSTER=false
REDIS_CLUSTER_NODES=localhost:6379

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# AES-256-GCM encrypted RSA-4096 private key (base64 encoded ciphertext)
JWT_PRIVATE_KEY_ENC=
# PEM-encoded RSA-4096 public key (single line, \n escaped)
JWT_PUBLIC_KEY=
# Key ID for the current signing key (used in JWKS kid claim)
JWT_KID=key-v1
JWT_ISSUER=https://uicp.example.com
JWT_AUDIENCE=uicp-api
JWT_ACCESS_TOKEN_TTL_S=900
JWT_REFRESH_TOKEN_TTL_S=604800

# ── Encryption (AES-256-GCM + HKDF) ──────────────────────────────────────────
# 64-character hex string (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=
ENCRYPTION_MASTER_KEY_ID=master-v1
# Optional: previous key for rotation support (decrypt old ciphertexts)
ENCRYPTION_DEPRECATED_KEY=
ENCRYPTION_DEPRECATED_KEY_ID=

# ── Credential Hashing ────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Minimum 32 characters. Generate with: openssl rand -base64 32
PASSWORD_PEPPER=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_S=86400
MAX_SESSIONS_PER_USER=10

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL_S=300

# ── Firebase (SMS OTP) ────────────────────────────────────────────────────────
# From your Firebase service account JSON (Google Cloud Console → IAM → Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the "private_key" value from the JSON — keep the \n escapes on a single line
FIREBASE_PRIVATE_KEY=

# ── SMTP (Email OTP) ──────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_FROM=noreply@uicp.example.com
MAIL_BRAND_NAME=Unified Identity Control Plane
MAIL_LOGO_URL=
MAIL_SUPPORT_EMAIL=support@uicp.example.com
MAIL_ACCENT_COLOR=#1d4ed8
MAIL_FOOTER_TEXT=If you did not request this message, you can safely ignore it.
PLATFORM_BASE_DOMAIN=app.uicp.example.com
MSG91_ENABLED=true
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_COUNTRY=91
MSG91_TEMPLATE_ID_IDENTITY_VERIFICATION=
MSG91_TEMPLATE_ID_MFA=
MSG91_TEMPLATE_ID_PASSWORD_RESET=
RESEND_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=noreply@uicp.example.com
MAILEROO_ENABLED=true
MAILEROO_API_KEY=
MAILEROO_FROM=noreply@uicp.example.com

# ── Audit Log ─────────────────────────────────────────────────────────────────
# HMAC key for audit log integrity checksums. Generate with: openssl rand -hex 32
AUDIT_HMAC_KEY=

# ── GeoIP ─────────────────────────────────────────────────────────────────────
# Path to the MaxMind GeoLite2-City.mmdb file
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# ── OIDC Discovery ────────────────────────────────────────────────────────────
OIDC_ISSUER=https://uicp.example.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug
